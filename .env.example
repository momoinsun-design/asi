# Database — Supabase Postgres.
# DATABASE_URL: Transaction pooler URI (port 6543) — used by app at runtime.
# DIRECT_URL:   Direct connection URI (port 5432)  — used by Prisma migrations.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# NextAuth — generate with `openssl rand -base64 32`
NEXTAUTH_SECRET="change-me-in-prod-generate-via-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ──────────────────────────────────────────────────────────────────────
# Stripe escrow — leave unset to use deterministic mock adapter
# When set, the app calls real Stripe test APIs (use test-mode keys).
# ──────────────────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_MODE="test"   # or "mock" (default when secret missing)

# ──────────────────────────────────────────────────────────────────────
# Creator Marketplace data sources
# ──────────────────────────────────────────────────────────────────────
# MOCK (default) returns the seeded corpus so the app runs without credentials.
# REAL dispatches per-platform to the official APIs below.
CREATOR_MARKETPLACE_MODE="MOCK"

# Instagram — Instagram API with Instagram Login (2024+)
# Docs: https://developers.facebook.com/docs/instagram-platform/instagram-api-with-instagram-login
# 1. Create an app at https://developers.facebook.com/apps → "Consumer" or "Business"
# 2. Add product "Instagram" → set Instagram app ID/secret
# 3. OAuth redirect URI: https://<your-domain>/api/auth/callback/instagram
# INSTAGRAM_APP_ID=""
# INSTAGRAM_APP_SECRET=""

# TikTok — Login Kit v2
# Docs: https://developers.tiktok.com/doc/login-kit-web
# 1. Create an app at https://developers.tiktok.com/apps
# 2. Enable "Login Kit" with scopes: user.info.basic, user.info.profile, user.info.stats
# 3. OAuth redirect URI: https://<your-domain>/api/auth/callback/tiktok
# TIKTOK_CLIENT_KEY=""
# TIKTOK_CLIENT_SECRET=""

# Instagram — Meta Creator Marketplace API (partnership-only, future)
# Requires Meta Business partnership approval + App Review.
# META_ACCESS_TOKEN=""
# META_BUSINESS_ID=""

# TikTok — Creator Marketplace API (TCM, partnership-only, future)
# Requires TikTok for Business partnership approval.
# TIKTOK_BUSINESS_ACCESS_TOKEN=""
# TIKTOK_ADVERTISER_ID=""

# YouTube Shorts — YouTube Data API v3 + creator OAuth (direct-signup)
# No Creator Marketplace equivalent exists; coverage grows from channels
# that link their account via OAuth.
# Docs: https://developers.google.com/youtube/v3
# YOUTUBE_API_KEY=""
# YOUTUBE_OAUTH_CLIENT_ID=""
# YOUTUBE_OAUTH_CLIENT_SECRET=""

# Demo-only toggle: auto-generate a canned influencer reply on outreach.
# Leave unset in staging / production.
# SIMULATE_INFLUENCER_REPLY="1"
